# Version
CONFIG_LOCALVERSION="-pearl"
CONFIG_UNAME_OVERRIDE=y
CONFIG_UNAME_OVERRIDE_TARGET="com.google.android.gms"
CONFIG_UNAME_OVERRIDE_STRING="5.10.198-android12-9-00085-g226a9632f13d-ab11136126"

# Camera
CONFIG_CUSTOM_KERNEL_IMGSENSOR="pearlov64b_mipi_raw pearlov16a1_mipi_raw pearls5k4h7_mipi_raw pearlgc02m1_mipi_raw"

# Charger
CONFIG_MTK_PUMP_EXPRESS_PLUS_SUPPORT=m
CONFIG_MTK_PUMP_EXPRESS_PLUS_20_SUPPORT=m
CONFIG_MTK_PUMP_EXPRESS_40_SUPPORT=m
CONFIG_MTK_PUMP_EXPRESS_50_SUPPORT=m
CONFIG_GAUGE_MT6375=m
CONFIG_REGULATOR_WL2868C=m
CONFIG_XMEXT_SC8551A_CHG_PUMP=m
CONFIG_XMEXT_LN8000_CHG_PUMP=m
CONFIG_XM_POWER=m

# Display
CONFIG_DRM_PANEL_LEDS_LM36273=m
CONFIG_DRM_PANEL_L16S_36_02_0A_DSC_VDO=m
CONFIG_DRM_PANEL_K6895V1_64_95T_ALPHA_CMD=m
CONFIG_MI_DISP_ESD_CHECK=y

# Fingerprint
CONFIG_MTK_FINGERPRINT_SUPPORT=m
CONFIG_FPC_MITEE_FINGERPRINT=m

# Product
CONFIG_BUILD_PRODUCT_NAME="pearl"
CONFIG_TARGET_PRODUCT_pearl=y

# Sound
CONFIG_SND_SOC_TFA9874=m
CONFIG_MIUS_IIO=m
CONFIG_MTK_VOW_BARGE_IN_SUPPORT=y
CONFIG_MTK_VOW_DUAL_MIC_SUPPORT=y
CONFIG_MTK_VOW_MAX_PDK_NUMBER=2
CONFIG_MTK_VOW_AMAZON_SUPPORT=n
CONFIG_MTK_VOW_GVA_SUPPORT=n
CONFIG_MTK_VOW_PCMCALLBACK_SUPPORT=n

# Tee
CONFIG_MITEE_SUPPORT=m

# Thermal
CONFIG_MI_THERMAL_ATC_ENABLE=y
CONFIG_MI_THERMAL_MULTI_CHARGE=y

# Touchscreen
CONFIG_TOUCHSCREEN_MT6983_ALPHA_SUPPORT=m
CONFIG_TOUCHSCREEN_MT6895_ALPHA_SUPPORT=m
CONFIG_TOUCHSCREEN_XIAOMI_TOUCHFEATURE=m
CONFIG_TOUCHSCREEN_NVT36672C_HOSTDL_SPI_NEW=m
CONFIG_TOUCHSCREEN_NVT36672C_DOUBLE_CLICK=m
